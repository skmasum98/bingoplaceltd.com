---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Our Services | BINGOPLACE LIMITED | Wholesale & Distribution Manchester">
  <!-- Hero Section -->
  <section class="bg-linear-to-br from-blue-900 to-blue-700 text-white">
    <div class="container mx-auto px-4 py-16 md:py-20">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          Our Services
        </h1>
        <div class="w-20 h-1 bg-yellow-500 mx-auto mb-6"></div>
        <p class="text-xl text-blue-100">
          Comprehensive wholesale and distribution solutions tailored to your business needs
        </p>
      </div>
    </div>
  </section>

  <!-- Main Services Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          What We Offer
        </h2>
        <div class="w-20 h-1 bg-yellow-500 mx-auto mb-6"></div>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          As a non-specialised wholesale trade company (SIC Code 46900), we provide flexible, scalable solutions across multiple sectors
        </p>
      </div>

      <!-- Service Cards Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
        
        <!-- Service 1: Wholesale Distribution -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition duration-300 group">
          <div class="bg-linear-to-r from-blue-600 to-blue-700 p-6">
            <div class="text-white">
              <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Wholesale Distribution</h3>
            <p class="text-gray-600 mb-4">
              Efficient and reliable distribution networks across the United Kingdom, ensuring your products reach their destination on time, every time.
            </p>
            <ul class="space-y-2 text-sm text-gray-600">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-green-500 mr-2 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Nationwide coverage
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-green-500 mr-2 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Real-time tracking
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-green-500 mr-2 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Flexible delivery options
              </li>
            </ul>
          </div>
        </div>

        <!-- Service 2: Supply Chain Management -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition duration-300 group">
          <div class="bg-linear-to-r from-blue-600 to-blue-700 p-6">
            <div class="text-white">
              <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
