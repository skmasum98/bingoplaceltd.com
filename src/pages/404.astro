---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page Not Found | BINGOPLACE LIMITED">
  <!-- 404 Content -->
  <section class="min-h-screen bg-linear-to-br from-blue-900 to-blue-700 flex items-center justify-center py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <!-- 404 Number -->
        <div class="mb-8">
          <h1 class="text-8xl md:text-9xl font-bold text-white opacity-20">404</h1>
          <div class="relative -mt-16 md:-mt-20">
            <svg class="w-24 h-24 md:w-32 md:h-32 mx-auto text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
        </div>

        <!-- Error Message -->
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Oops! Page Not Found
        </h2>
        <div class="w-20 h-1 bg-yellow-500 mx-auto mb-6"></div>
        <p class="text-xl text-blue-100 mb-8">
          We couldn't find the page you were looking for. The page might have been moved, deleted, or the URL might be incorrect.
        </p>

        <!-- Search Box -->
        <div class="max-w-md mx-auto mb-8">
          <form action="/search" method="GET" class="relative">
            <input 
              type="text" 
              name="q" 
              placeholder="Search our website..."
              class="w-full px-5 py-3 pr-12 rounded-full bg-white text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-yellow-500"
            />
            <button type="submit" class="absolute right-3 top-1/2 transform -translate-y-1/2 text-blue-600 hover:text-blue-700">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </button>
          </form>
        </div>

        <!-- Quick Links -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto mb-8">
          <a href="/" class="bg-white bg-opacity-20 hover:bg-opacity-30 text-zinc-950 font-semibold py-3 px-6 rounded-lg transition duration-300 flex items-center justify-center space-x-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
            <span >Back to Home</span>
          </a>
          <a href="/contact" class="bg-yellow-500 hover:bg-yellow-600 text-blue-900 font-semibold py-3 px-6 rounded-lg transition duration-300 flex items-center justify-center space-x-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <span>Contact Support</span>
          </a>
        </div>

        <!-- Helpful Links Section -->
        <div class="bg-white bg-opacity-10 rounded-lg p-6 max-w-2xl mx-auto">
          <h3 class="text-zinc-950 font-semibold mb-4">Popular Pages</h3>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
            <a href="/" class="text-zinc-950 hover:text-white text-sm transition">Home</a>
            <a href="/about" class="text-zinc-950 hover:text-white text-sm transition">About Us</a>
            <a href="/services" class="text-zinc-950 hover:text-white text-sm transition">Services</a>
            <a href="/products" class="text-zinc-950 hover:text-white text-sm transition">Products</a>
            <a href="/contact" class="text-zinc-950 hover:text-white text-sm transition">Contact</a>
            <a href="/privacy" class="text-zinc-950 hover:text-white text-sm transition">Privacy Policy</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>