---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact Us | BINGOPLACE LIMITED | Wholesale & Distribution Manchester">
  <!-- Hero Section -->
  <section class="bg-linear-to-br from-blue-900 to-blue-700 text-white">
    <div class="container mx-auto px-4 py-16 md:py-20">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          Contact Us
        </h1>
        <div class="w-20 h-1 bg-yellow-500 mx-auto mb-6"></div>
        <p class="text-xl text-blue-100">
          Get in touch with BINGOPLACE LIMITED. We're here to help with your wholesale and distribution needs
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Information & Form Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8">
          <!-- Contact Information -->
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">
              Get In Touch
            </h2>
            <p class="text-gray-600 mb-8">
              Have questions about our services or ready to start working with us? Reach out using the form or through any of the channels below.
            </p>

            <!-- Registered Office Card -->
            <div class="bg-gray-50 rounded-lg p-6 mb-6 shadow-md">
              <div class="flex items-start space-x-4">
                <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-gray-900 mb-2">Registered Office</h3>
                  <p class="text-gray-600">
                    76 King Street<br />
                    Manchester<br />
                    England<br />
                    M2 4NH<br />
                    United Kingdom
                  </p>
                </div>
              </div>
            </div>

            <!-- Email Card -->
            <div class="bg-gray-50 rounded-lg p-6 mb-6 shadow-md">
              <div class="flex items-start space-x-4">
                <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-gray-900 mb-2">Email Us</h3>
                  <p class="text-gray-600 mb-1">
                    <a href="mailto:info@bingoplace.co.uk" class="text-blue-600 hover:text-blue-700 transition">
                      info@bingoplace.co.uk
                    </a>
                  </p>
                  <p class="text-sm text-gray-500">
                    We aim to respond within 24 hours
                  </p>
                </div>
              </div>
            </div>

            <!-- Phone Card -->
            <div class="bg-gray-50 rounded-lg p-6 mb-6 shadow-md">
              <div class="flex items-start space-x-4">
                <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-gray-900 mb-2">Call Us</h3>
                  <p class="text-gray-600 mb-1">
                    <a href="tel:+441611234567" class="text-blue-600 hover:text-blue-700 transition">
                      +44 (0)161 123 4567
                    </a>
                  </p>
                  <p class="text-sm text-gray-500">
                    Monday - Friday, 9:00 AM - 5:00 PM
                  </p>
                </div>
              </div>
            </div>

            <!-- Business Hours Card -->
            <div class="bg-gray-50 rounded-lg p-6 shadow-md">
              <div class="flex items-start space-x-4">
                <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-gray-900 mb-2">Business Hours</h3>
                  <div class="space-y-1 text-gray-600">
                    <p>Monday - Friday: 9:00 AM - 5:00 PM</p>
                    <p>Saturday: Closed</p>
                    <p>Sunday: Closed</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Contact Form -->
          <div>
            <div class="bg-gray-50 rounded-lg shadow-lg p-8">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">
                Send Us a Message
              </h2>
              <p class="text-gray-600 mb-6">
                Fill out the form below and we'll get back to you as soon as possible.
              </p>

              <form action="#" method="POST" class="space-y-5">
                <div>
                  <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
                    Full Name <span class="text-red-500">*</span>
                  </label>
                  <input 
                    type="text" 
                    id="name" 
                    name="name" 
                    required 
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition outline-none"
                    placeholder="John Doe"
                  />
                </div>

                <div>
                  <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
                    Email Address <span class="text-red-500">*</span>
                  </label>
                  <input 
                    type="email" 
                    id="email" 
                    name="email" 
                    required 
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition outline-none"
                    placeholder="john@example.com"
                  />
                </div>

                <div>
                  <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">
                    Phone Number
                  </label>
                  <input 
                    type="tel" 
                    id="phone" 
                    name="phone" 
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition outline-none"
                    placeholder="+44 (0)161 123 4567"
                  />
                </div>

                <div>
                  <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">
                    Subject <span class="text-red-500">*</span>
                  </label>
                  <select 
                    id="subject" 
                    name="subject" 
                    required 
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition outline-none"
                  >
                    <option value="">Select a subject</option>
                    <option value="general">General Inquiry</option>
                    <option value="services">Services Information</option>
                    <option value="partnership">Partnership Opportunities</option>
                    <option value="quote">Request a Quote</option>
                    <option value="support">Support</option>
                    <option value="other">Other</option>
                  </select>
                </div>

                <div>
                  <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
                    Message <span class="text-red-500">*</span>
                  </label>
                  <textarea 
                    id="message" 
                    name="message" 
                    rows="5" 
                    required 
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition outline-none"
                    placeholder="Tell us how we can help you..."
                  ></textarea>
                </div>

                <div>
                  <label class="flex items-start space-x-2">
                    <input 
                      type="checkbox" 
                      name="consent" 
                      required 
                      class="mt-1 text-blue-600 focus:ring-blue-500 border-gray-300 rounded"
                    />
                    <span class="text-sm text-gray-600">
                      I consent to BINGOPLACE LIMITED storing and processing my personal data to respond to my inquiry. 
                      <a href="/privacy" class="text-blue-600 hover:text-blue-700">Privacy Policy</a>
                    </span>
                  </label>
                </div>

                <button 
                  type="submit" 
                  class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-4 rounded-lg transition duration-300 transform hover:scale-[1.02]"
                >
                  Send Message
                </button>

                <p class="text-xs text-gray-500 text-center mt-4">
                  This site is protected by reCAPTCHA and the Google 
                  <a href="https://policies.google.com/privacy" class="text-blue-600 hover:text-blue-700" target="_blank">Privacy Policy</a> and 
                  <a href="https://policies.google.com/terms" class="text-blue-600 hover:text-blue-700" target="_blank">Terms of Service</a> apply.
                </p>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
          Find Us
        </h2>
        <div class="w-20 h-1 bg-yellow-500 mx-auto mb-6"></div>
        <p class="text-lg text-gray-600">
          Visit our registered office in Manchester
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="relative h-96 bg-gray-200">
            <!-- Google Maps Embed - Replace with actual embed code -->
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2374.699229078739!2d-2.2457506!3d53.4801789!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x487bb1e6d5e2b2b7%3A0x5e5c5e5c5e5c5e5c!2s76%20King%20St%2C%20Manchester%20M2%204NH!5e0!3m2!1sen!2suk!4v1700000000000!5m2!1sen!2suk" 
              width="100%" 
              height="100%" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade"
              title="BINGOPLACE LIMITED Office Location"
              class="absolute inset-0 w-full h-full"
            ></iframe>
          </div>
          <div class="p-6 bg-white">
            <div class="flex items-start space-x-3">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <div>
                <p class="text-gray-800">
                  <strong class="font-semibold">BINGOPLACE LIMITED</strong><br />
                  76 King Street<br />
                  Manchester, England<br />
                  M2 4NH<br />
                  United Kingdom
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
          Frequently Asked Questions
        </h2>
        <div class="w-20 h-1 bg-yellow-500 mx-auto mb-6"></div>
        <p class="text-lg text-gray-600">
          Quick answers to common questions
        </p>
      </div>

      <div class="max-w-3xl mx-auto space-y-4">
        <div class="bg-gray-50 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">
            What are your business hours?
          </h3>
          <p class="text-gray-600">
            We are open Monday to Friday, 9:00 AM to 5:00 PM (GMT). We are closed on weekends and public holidays.
          </p>
        </div>

        <div class="bg-gray-50 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">
            How quickly do you respond to inquiries?
          </h3>
          <p class="text-gray-600">
            We aim to respond to all inquiries within 24 business hours. For urgent matters, please call us directly.
          </p>
        </div>

        <div class="bg-gray-50 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">
            Do you offer international shipping?
          </h3>
          <p class="text-gray-600">
            Currently, our services are focused on the United Kingdom market. Please contact us for specific inquiries about international distribution.
          </p>
        </div>

        <div class="bg-gray-50 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">
            How can I become a partner?
          </h3>
          <p class="text-gray-600">
            We're always looking for strategic partners. Please fill out the contact form with "Partnership Opportunities" as the subject, and our team will get in touch.
          </p>
        </div>

        <div class="bg-gray-50 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">
            Is my personal information secure?
          </h3>
          <p class="text-gray-600">
            Yes, we take data protection seriously. All personal information is handled in accordance with UK data protection laws. See our Privacy Policy for more details.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-blue-900 text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">
        Ready to Work With BINGOPLACE LIMITED?
      </h2>
      <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
        Let's discuss how we can support your wholesale and distribution needs
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="mailto:info@bingoplace.co.uk" class="inline-block bg-yellow-500 hover:bg-yellow-600 text-blue-900 font-semibold px-8 py-3 rounded-lg transition duration-300 transform hover:scale-105">
          Email Us Now
        </a>
        <a href="tel:+441611234567" class="inline-block bg-transparent border-2 border-white hover:bg-white hover:text-blue-900 text-white font-semibold px-8 py-3 rounded-lg transition duration-300">
          Call Us
        </a>
      </div>
    </div>
  </section>
</Layout>