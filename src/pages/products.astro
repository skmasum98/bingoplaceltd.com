      </a>
    </div>
  </section>
</Layout>

<script>
  // Sticky category navigation active state
  const categories = document.querySelectorAll('.category-link');
  const sections = ['all', 'electronics', 'home-garden', 'fashion', 'health-beauty', 'sports', 'toys', 'office'];
  
  function updateActiveCategory() {
    const scrollPosition = window.scrollY + 200;
    
    for (const section of sections) {
      const element = document.getElementById(section);
      if (element) {
        const offsetTop = element.offsetTop;
        const offsetBottom = offsetTop + element.offsetHeight;
        
        if (scrollPosition >= offsetTop && scrollPosition < offsetBottom) {
          categories.forEach(link => {
            link.classList.remove('text-blue-600', 'border-b-2', 'border-blue-600');
            link.classList.add('text-gray-600');
          });
          
          const activeLink = document.querySelector(`.category-link[href="#${section}"]`);
          if (activeLink) {
            activeLink.classList.remove('text-gray-600');
            activeLink.classList.add('text-blue-600', 'border-b-2', 'border-blue-600');
          }
          break;
        }
      }
    }
  }
  
  window.addEventListener('scroll', updateActiveCategory);
  window.addEventListener('load', updateActiveCategory);
</script>