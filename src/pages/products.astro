          <p class="text-sm text-gray-600">Cables, chargers & more</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Home & Garden Category -->
  <section id="home-garden" class="py-16 bg-white scroll-mt-24">
    <div class="container mx-auto px-4">
      <div class="flex justify-between items-center mb-8">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-2">Home & Garden</h2>
          <div class="w-16 h-1 bg-yellow-500"></div>
        </div>
        <a href="#all" class="text-blue-600 hover:text-blue-700 font-semibold">View All →</a>
