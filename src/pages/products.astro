        </div>
        
        <div class="bg-gray-50 rounded-lg shadow-md p-4 text-center hover:shadow-lg transition">
          <div class="h-32 flex items-center justify-center mb-3">
            <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 15l7-7 7 7"></path>
