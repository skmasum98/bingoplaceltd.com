---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Our Products | BINGOPLACE LIMITED | Wholesale & Distribution Manchester">
  <!-- Hero Section -->
  <section class="bg-linear-to-br from-blue-900 to-blue-700 text-white">
    <div class="container mx-auto px-4 py-16 md:py-20">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          Our Products
        </h1>
        <div class="w-20 h-1 bg-yellow-500 mx-auto mb-6"></div>
        <p class="text-xl text-blue-100">
          High-quality wholesale products across multiple categories, sourced from trusted suppliers
        </p>
      </div>
    </div>
  </section>

  <!-- Product Categories Navigation -->
  <section class="sticky top-16 z-40 bg-white border-b border-gray-200 shadow-sm">
    <div class="container mx-auto px-4">
      <div class="flex overflow-x-auto py-4 space-x-4 scrollbar-hide">
        <a href="#all" class="category-link px-4 py-2 text-blue-600 border-b-2 border-blue-600 font-semibold whitespace-nowrap">All Products</a>
        <a href="#electronics" class="category-link px-4 py-2 text-gray-600 hover:text-blue-600 whitespace-nowrap">Electronics</a>
        <a href="#home-garden" class="category-link px-4 py-2 text-gray-600 hover:text-blue-600 whitespace-nowrap">Home & Garden</a>
        <a href="#fashion" class="category-link px-4 py-2 text-gray-600 hover:text-blue-600 whitespace-nowrap">Fashion & Apparel</a>
        <a href="#health-beauty" class="category-link px-4 py-2 text-gray-600 hover:text-blue-600 whitespace-nowrap">Health & Beauty</a>
        <a href="#sports" class="category-link px-4 py-2 text-gray-600 hover:text-blue-600 whitespace-nowrap">Sports & Outdoors</a>
        <a href="#toys" class="category-link px-4 py-2 text-gray-600 hover:text-blue-600 whitespace-nowrap">Toys & Games</a>
        <a href="#office" class="category-link px-4 py-2 text-gray-600 hover:text-blue-600 whitespace-nowrap">Office Supplies</a>
      </div>
    </div>
  </section>

  <!-- All Products Section -->
  <section id="all" class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Featured Products
        </h2>
        <div class="w-20 h-1 bg-yellow-500 mx-auto mb-6"></div>
        <p class="text-lg text-gray-600">
          Explore our extensive range of wholesale products
        </p>
      </div>

      <!-- Product Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        
        <!-- Product 1 -->
        <div class="group bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition duration-300">
          <div class="relative overflow-hidden bg-gray-100 h-64">
            <div class="absolute top-4 left-4 z-10">
              <span class="bg-yellow-500 text-blue-900 text-xs font-bold px-2 py-1 rounded">Bestseller</span>
            </div>
            <div class="flex items-center justify-center h-full bg-linear-to-br from-gray-50 to-gray-100">
              <svg class="w-24 h-24 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
          </div>
          <div class="p-5">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Premium Electronics Bundle</h3>
            <p class="text-gray-600 text-sm mb-3">High-quality electronics assortment perfect for retail and distribution.</p>
            <div class="flex items-center justify-between mb-4">
              <span class="text-2xl font-bold text-blue-600">£49.99</span>
              <span class="text-sm text-gray-500">wholesale price</span>
            </div>
            <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
              <span>MOQ: 50 units</span>
              <span>In Stock</span>
            </div>
            <button class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-300">
              Request Quote
            </button>
          </div>
        </div>

        <!-- Product 2 -->
        <div class="group bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition duration-300">
          <div class="relative overflow-hidden bg-gray-100 h-64">
            <div class="flex items-center justify-center h-full bg-linear-to-br from-gray-50 to-gray-100">
              <svg class="w-24 h-24 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
              </svg>
            </div>
          </div>
          <div class="p-5">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Home & Garden Collection</h3>
            <p class="text-gray-600 text-sm mb-3">Complete home and garden essentials for modern living.</p>
            <div class="flex items-center justify-between mb-4">
              <span class="text-2xl font-bold text-blue-600">£29.99</span>
              <span class="text-sm text-gray-500">wholesale price</span>
            </div>
            <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
              <span>MOQ: 100 units</span>
              <span>In Stock</span>
            </div>
            <button class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-300">
              Request Quote
            </button>
          </div>
        </div>

        <!-- Product 3 -->
        <div class="group bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition duration-300">
          <div class="relative overflow-hidden bg-gray-100 h-64">
            <div class="absolute top-4 left-4 z-10">
              <span class="bg-green-500 text-white text-xs font-bold px-2 py-1 rounded">New</span>
            </div>
            <div class="flex items-center justify-center h-full bg-linear-to-br from-gray-50 to-gray-100">
              <svg class="w-24 h-24 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
              </svg>
            </div>
          </div>
          <div class="p-5">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Fashion Apparel Bundle</h3>
            <p class="text-gray-600 text-sm mb-3">Trending fashion items for retail and boutique stores.</p>
            <div class="flex items-center justify-between mb-4">
              <span class="text-2xl font-bold text-blue-600">£39.99</span>
              <span class="text-sm text-gray-500">wholesale price</span>
            </div>
            <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
              <span>MOQ: 75 units</span>
              <span>Pre-order</span>
            </div>
            <button class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-300">
              Request Quote
            </button>
          </div>
        </div>

        <!-- Product 4 -->
        <div class="group bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition duration-300">
          <div class="relative overflow-hidden bg-gray-100 h-64">
            <div class="flex items-center justify-center h-full bg-linear-to-br from-gray-50 to-gray-100">
              <svg class="w-24 h-24 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.618 5.984A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016zM12 9v2m0 4h.01"></path>
              </svg>
            </div>
          </div>
          <div class="p-5">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Health & Wellness Set</h3>
            <p class="text-gray-600 text-sm mb-3">Premium health and beauty products for personal care.</p>
            <div class="flex items-center justify-between mb-4">
              <span class="text-2xl font-bold text-blue-600">£24.99</span>
              <span class="text-sm text-gray-500">wholesale price</span>
            </div>
            <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
              <span>MOQ: 200 units</span>
              <span>In Stock</span>
            </div>
            <button class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-300">
              Request Quote
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Category Sections -->
  
  <!-- Electronics Category -->
  <section id="electronics" class="py-16 bg-gray-50 scroll-mt-24">
    <div class="container mx-auto px-4">
      <div class="flex justify-between items-center mb-8">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-2">Electronics</h2>
          <div class="w-16 h-1 bg-yellow-500"></div>
        </div>
        <a href="#all" class="text-blue-600 hover:text-blue-700 font-semibold">View All →</a>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-lg shadow-md p-4 text-center hover:shadow-lg transition">
          <div class="h-32 flex items-center justify-center mb-3">
            <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-1">Smartphones</h3>
          <p class="text-sm text-gray-600">Latest models available</p>
