---
import Layout from "../layouts/Layout.astro";


const products = {
  softDrinks: [
    { name: "Carbonated Soft Drinks", description: "Various flavours in cans and bottles", size: "330ml-2L", format: "Cans/Bottles", image: "/images/soft-drinks.jpg" },
    { name: "Fruit Juices", description: "Orange, apple, tropical blends", size: "1L-2L", format: "Cartons/Bottles", image: "/images/fruit-juices.webp" },
    { name: "Energy Drinks", description: "Mainstream and value brands", size: "250ml-500ml", format: "Cans", image: "/images/energy-drinks.avif" },
    { name: "Bottled Water", description: "Still and sparkling options", size: "500ml-1.5L", format: "PET Bottles", image: "/images/bottled-water.jpg" },
    { name: "Sports Drinks", description: "Isotonic beverages", size: "500ml-1L", format: "Bottles", image: "/images/sports-drinks.jpg" },
    { name: "Mixers", description: "Tonic, soda, ginger ale", size: "200ml-1L", format: "Bottles", image: "/images/mixers.jpg" }
  ],
  personalCare: [
    { name: "Hand Soaps", description: "Liquid and bar formats", size: "250ml-5L", format: "Bottles/Packs", image: "/images/hand-soaps.jpg" },
    { name: "Shower Gels", description: "Various scents and formulas", size: "250ml-1L", format: "Bottles", image: "/images/shower-gels.jpg" },
    { name: "Body Lotions", description: "Moisturizing creams", size: "250ml-500ml", format: "Tubes/Bottles", image: "/images/body-lotions.jpg" },
    { name: "Hair Care", description: "Shampoos and conditioners", size: "250ml-1L", format: "Bottles", image: "/images/hair-care.jpg" },
    { name: "Oral Care", description: "Toothpaste and brushes", size: "50ml-100ml", format: "Tubes/Packs", image: "/images/oral-care.jpg" },
    { name: "Deodorants", description: "Spray and roll-on", size: "150ml-250ml", format: "Cans/Bottles", image: "/images/deodorants.jpg" }
  ],
  householdGoods: [
    { name: "Surface Cleaners", description: "Multi-surface sprays", size: "500ml-1L", format: "Spray Bottles", image: "/images/surface-cleaners.jpg" },
    { name: "Floor Cleaners", description: "All floor types", size: "1L-5L", format: "Bottles", image: "/images/floor-cleaners.jpg" },
    { name: "Laundry Detergent", description: "Liquid and powder", size: "1L-3L", format: "Bottles/Boxes", image: "/images/laundry-detergent.jpg" },
    { name: "Dish Soap", description: "Hand washing liquids", size: "500ml-1L", format: "Bottles", image: "/images/dish-soap.jpg" },
    { name: "Air Fresheners", description: "Spray and automatic", size: "300ml-500ml", format: "Sprays/Diffusers", image: "/images/air-fresheners.jpg" },
    { name: "Cleaning Cloths", description: "Microfibre and disposable", size: "Packs of 10-50", format: "Packaged", image: "/images/cleaning-cloths.jpg" }
  ]
};
---

<Layout 
  title="Products | BingoPlace Ltd - UK Wholesale Supplier of Soft Drinks, Personal Care, and Household Goods"
  description="Explore the range of products supplied by BingoPlace, a UK-based wholesale trade company. We offer soft drinks, personal care items, and household goods for trade customers."
  
>

  <!-- Hero Section -->
  <section class="relative bg-linear-to-br from-blue-50 to-slate-100 py-16 md:py-24 overflow-hidden">
    <!-- Background elements -->
    <div class="absolute inset-0 opacity-30">
      <div class="absolute top-10 left-10 w-64 h-64 bg-blue-200 rounded-full mix-blend-multiply filter blur-xl"></div>
      <div class="absolute bottom-10 right-10 w-64 h-64 bg-slate-200 rounded-full mix-blend-multiply filter blur-xl"></div>
    </div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
      <div class="max-w-3xl">
        <!-- Breadcrumb -->
        <div class="flex items-center gap-2 text-blue-600 mb-6">
          <a href="/" class="text-sm hover:text-blue-800 transition-colors">Home</a>
          <span class="text-blue-400">/</span>
          <span class="text-sm font-medium text-slate-700">Products</span>
        </div>
        
        <h1 class="text-3xl font-bold text-slate-900 mb-4
                   sm:text-4xl
                   md:text-5xl">
          Our <span class="text-blue-600">Product Range</span>
        </h1>

        <div class="mt-6 pl-6 border-l-4 border-blue-500">
          <p class="text-lg text-slate-600 md:text-xl">
            Premium wholesale products across essential categories, supplied to trade 
            customers and retailers across the United Kingdom.
          </p>
        </div>

        <!-- Quick Stats -->
        <div class="mt-10 grid grid-cols-2 sm:grid-cols-3 gap-4">
          
          <div class="bg-white/80 backdrop-blur-sm rounded-xl p-4 shadow-sm border border-slate-200">
            <div class="text-2xl font-bold text-blue-600">1800+</div>
            <div class="text-sm text-slate-600 mt-1">Product Types</div>
          </div>
          <div class="bg-white/80 backdrop-blur-sm rounded-xl p-4 shadow-sm border border-slate-200 hidden sm:block">
            <div class="text-2xl font-bold text-blue-600">UK</div>
            <div class="text-sm text-slate-600 mt-1">Nationwide Supply</div>
          </div>
        </div>

        <!-- Quick Navigation -->
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="#soft-drinks" 
             class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition-all">
            🥤 Soft Drinks
          </a>
          <a href="#personal-care" 
             class="inline-flex items-center gap-2 px-4 py-2 bg-green-600 text-white text-sm font-semibold rounded-lg hover:bg-green-700 transition-all">
            🧴 Personal Care
          </a>
          <a href="#household-goods" 
             class="inline-flex items-center gap-2 px-4 py-2 bg-amber-600 text-white text-sm font-semibold rounded-lg hover:bg-amber-700 transition-all">
            🏠 Household Goods
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Product Gallery Preview -->
  

  <!-- Soft Drinks Section -->
  <section id="soft-drinks" class="bg-linear-to-b from-blue-50 to-white py-12 md:py-20 scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col md:flex-row md:items-start md:gap-12 mb-10 md:mb-16">
        <div class="md:w-1/3 mb-8 md:mb-0">
          <div class="inline-flex items-center gap-2 bg-blue-100 text-blue-700 text-xs font-semibold 
                      px-4 py-2 rounded-full mb-4">
            <span class="text-lg">🥤</span>
            Category 1
          </div>
          <h2 class="text-2xl font-bold text-slate-900 mb-3
                     sm:text-3xl">
            Soft Drinks
          </h2>
          <p class="text-slate-600 text-sm sm:text-base leading-relaxed">
            Comprehensive range of non-alcoholic beverages supplied in wholesale 
            quantities for retail distribution across the UK.
          </p>
          
          <div class="mt-6 bg-white rounded-xl p-4 border border-blue-100 shadow-sm">
            <p class="text-sm font-semibold text-slate-900 mb-2">Typical Packaging</p>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-blue-100 text-blue-700 text-xs rounded-full">Cans</span>
              <span class="px-3 py-1 bg-blue-100 text-blue-700 text-xs rounded-full">Bottles</span>
              <span class="px-3 py-1 bg-blue-100 text-blue-700 text-xs rounded-full">Cartons</span>
              <span class="px-3 py-1 bg-blue-100 text-blue-700 text-xs rounded-full">Multi-packs</span>
            </div>
          </div>
        </div>
        
        <div class="md:w-2/3">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {products.softDrinks.map((product, index) => (
              <div class="group bg-white rounded-xl p-5 border border-slate-200 
                         hover:border-blue-300 hover:shadow-lg transition-all duration-300">
                {/* Product Image Placeholder */}
                  <div class="w-full rounded-lg bg-blue-100 flex items-center justify-center">
                    <span class="text-lg">{product.image ? <img src={product.image} alt={product.name} class="w-full h-full object-cover rounded-lg" /> : '🥤'}</span>
                  </div>
                <div class="flex items-start justify-between mb-3">
                  
                  <div>
                    <h3 class="font-semibold text-slate-900 text-sm sm:text-base">
                      {product.name}
                    </h3>
                    <p class="text-xs text-slate-500 mt-1">{product.description}</p>
                  </div>
                  <span class="text-lg opacity-50 group-hover:opacity-100 transition-opacity">🥤</span>
                </div>
                <div class="flex items-center justify-between text-xs text-slate-600 mt-4 pt-4 border-t border-slate-100">
                  <span class="font-medium">{product.size}</span>
                  <span class="bg-blue-50 text-blue-700 px-2 py-1 rounded">
                    {product.format}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Personal Care Section -->
  <section id="personal-care" class="bg-linear-to-b from-green-50 to-white py-12 md:py-20 scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col md:flex-row md:items-start md:gap-12 mb-10 md:mb-16">
        <div class="md:w-1/3 mb-8 md:mb-0">
          <div class="inline-flex items-center gap-2 bg-green-100 text-green-700 text-xs font-semibold 
                      px-4 py-2 rounded-full mb-4">
            <span class="text-lg">🧴</span>
            Category 2
          </div>
          <h2 class="text-2xl font-bold text-slate-900 mb-3
                     sm:text-3xl">
            Personal Care Products
          </h2>
          <p class="text-slate-600 text-sm sm:text-base leading-relaxed">
            Essential personal hygiene and care items supplied in bulk for 
            retail distribution to meet everyday consumer needs.
          </p>
          
          <div class="mt-6 bg-white rounded-xl p-4 border border-green-100 shadow-sm">
            <p class="text-sm font-semibold text-slate-900 mb-2">Typical Applications</p>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-green-100 text-green-700 text-xs rounded-full">Bathroom</span>
              <span class="px-3 py-1 bg-green-100 text-green-700 text-xs rounded-full">Skincare</span>
              <span class="px-3 py-1 bg-green-100 text-green-700 text-xs rounded-full">Haircare</span>
              <span class="px-3 py-1 bg-green-100 text-green-700 text-xs rounded-full">Oral Care</span>
            </div>
          </div>
        </div>
        
        <div class="md:w-2/3">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {products.personalCare.map((product, index) => (
              <div class="group bg-white rounded-xl p-5 border border-slate-200 
                         hover:border-green-300 hover:shadow-lg transition-all duration-300">
                <div class="w-full rounded-lg bg-blue-100 flex items-center justify-center">
                    <span class="text-lg">{product.image ? <img src={product.image} alt={product.name} class="w-full h-full object-cover rounded-lg" /> : '🥤'}</span>
                </div>
                <div class="flex items-start justify-between mb-3">
                  <div>
                    <h3 class="font-semibold text-slate-900 text-sm sm:text-base">
                      {product.name}
                    </h3>
                    <p class="text-xs text-slate-500 mt-1">{product.description}</p>
                  </div>
                  <span class="text-lg opacity-50 group-hover:opacity-100 transition-opacity">🧴</span>
                </div>
                <div class="flex items-center justify-between text-xs text-slate-600 mt-4 pt-4 border-t border-slate-100">
                  <span class="font-medium">{product.size}</span>
                  <span class="bg-green-50 text-green-700 px-2 py-1 rounded">
                    {product.format}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Household Goods Section -->
  <section id="household-goods" class="bg-linear-to-b from-amber-50 to-white py-12 md:py-20 scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col md:flex-row md:items-start md:gap-12 mb-10 md:mb-16">
        <div class="md:w-1/3 mb-8 md:mb-0">
          <div class="inline-flex items-center gap-2 bg-amber-100 text-amber-700 text-xs font-semibold 
                      px-4 py-2 rounded-full mb-4">
            <span class="text-lg">🏠</span>
            Category 3
          </div>
          <h2 class="text-2xl font-bold text-slate-900 mb-3
                     sm:text-3xl">
            Household Goods
          </h2>
          <p class="text-slate-600 text-sm sm:text-base leading-relaxed">
            Essential cleaning and household products supplied in wholesale 
            quantities for retail and commercial use.
          </p>
          
          <div class="mt-6 bg-white rounded-xl p-4 border border-amber-100 shadow-sm">
            <p class="text-sm font-semibold text-slate-900 mb-2">Common Uses</p>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-amber-100 text-amber-700 text-xs rounded-full">Cleaning</span>
              <span class="px-3 py-1 bg-amber-100 text-amber-700 text-xs rounded-full">Laundry</span>
              <span class="px-3 py-1 bg-amber-100 text-amber-700 text-xs rounded-full">Kitchen</span>
              <span class="px-3 py-1 bg-amber-100 text-amber-700 text-xs rounded-full">Maintenance</span>
            </div>
          </div>
        </div>
        
        <div class="md:w-2/3">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {products.householdGoods.map((product, index) => (
              <div class="group bg-white rounded-xl p-5 border border-slate-200 
                         hover:border-amber-300 hover:shadow-lg transition-all duration-300">
                <div class="w-full rounded-lg bg-blue-100 flex items-center justify-center">
                    <span class="text-lg">{product.image ? <img src={product.image} alt={product.name} class="w-full h-full object-cover rounded-lg" /> : '🥤'}</span>
                </div>
                <div class="flex items-start justify-between mb-3">
                  <div>
                    <h3 class="font-semibold text-slate-900 text-sm sm:text-base">
                      {product.name}
                    </h3>
                    <p class="text-xs text-slate-500 mt-1">{product.description}</p>
                  </div>
                  <span class="text-lg opacity-50 group-hover:opacity-100 transition-opacity">🏠</span>
                </div>
                <div class="flex items-center justify-between text-xs text-slate-600 mt-4 pt-4 border-t border-slate-100">
                  <span class="font-medium">{product.size}</span>
                  <span class="bg-amber-50 text-amber-700 px-2 py-1 rounded">
                    {product.format}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Wholesale Notice -->
  <section class="bg-linear-to-r from-slate-800 to-slate-900 py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 md:p-8 border border-white/20">
        <div class="flex flex-col md:flex-row md:items-center md:gap-8">
          <div class="md:w-1/4 mb-6 md:mb-0">
            <div class="w-16 h-16 rounded-xl bg-white/20 flex items-center justify-center mx-auto md:mx-0">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
              </svg>
            </div>
          </div>
          <div class="md:w-3/4">
            <h3 class="text-xl font-bold text-white mb-3">Important Trade Notice</h3>
            <div class="text-slate-200 text-sm sm:text-base">
              <p class="mb-3">
                All products are supplied exclusively on a wholesale and trade basis to business customers. 
                Availability, minimum order quantities, and specifications may vary based on current stock 
                and market conditions.
              </p>
              <p>
                For detailed product specifications, pricing, and availability, please contact our trade team 
                directly with your business requirements.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-linear-to-r from-blue-600 to-blue-700 py-12 md:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
      <div class="inline-block mb-6">
        <span class="text-sm font-semibold text-blue-200 uppercase tracking-wider">Get Pricing</span>
        <div class="h-1 w-12 bg-white mt-2 mx-auto"></div>
      </div>
      
      <h2 class="text-2xl font-bold text-white mb-6
                 sm:text-3xl
                 md:text-4xl">
        Request Wholesale Pricing
      </h2>

      <p class="text-lg text-blue-100 max-w-2xl mx-auto mb-8">
        Interested in our product range? Contact our trade team for wholesale 
        pricing, minimum order quantities, and delivery options.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact"
           class="inline-flex items-center justify-center gap-2
                  px-8 py-4 bg-white text-blue-600 font-semibold rounded-xl 
                  hover:bg-slate-50 transition-all duration-300 
                  active:scale-95 transform shadow-lg hover:shadow-xl">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          Request Price List
        </a>
        
        <a href="tel:+441234567890"
           class="inline-flex items-center justify-center gap-2
                  px-8 py-4 bg-blue-800 text-white font-semibold rounded-xl 
                  hover:bg-blue-900 transition-all duration-300 
                  active:scale-95 transform border border-blue-500/30">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
          Call Trade Team
        </a>
      </div>
      
      <p class="mt-8 text-sm text-blue-200">
        Response within 24 hours • Bulk discount available • UK-wide delivery
      </p>
    </div>
  </section>

  <!-- Floating Navigation for Mobile -->
  <div class="fixed bottom-6 right-6 z-50 md:hidden">
    <div class="relative">
      <button onclick="scrollToTop()"
             class="flex items-center justify-center
                    w-14 h-14 rounded-full
                    bg-linear-to-r from-blue-600 to-blue-700 text-white
                    shadow-lg hover:shadow-xl
                    active:scale-95 transform transition-all duration-300
                    border border-blue-500">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 11l7-7 7 7M5 19l7-7 7 7"></path>
        </svg>
      </button>
    </div>
  </div>

</Layout>

<script>
  function scrollToTop() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
</script>

<style>
  /* Smooth scrolling for anchor links */
  html {
    scroll-behavior: smooth;
  }
  
  /* Mobile touch improvements */
  @media (max-width: 640px) {
    [id] {
      scroll-margin-top: 80px;
    }
    
    .scroll-mt-20 {
      scroll-margin-top: 80px;
    }
  }
</style>