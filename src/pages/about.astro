  <!-- Values Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Our Values
        </h2>
        <div class="w-20 h-1 bg-yellow-500 mx-auto mb-6"></div>
        <p class="text-lg text-gray-600">
          The principles that guide everything we do
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center p-6">
          <div class="inline-block p-3 bg-blue-100 rounded-full mb-4">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Integrity</h3>
          <p class="text-gray-600">Honest, transparent, and ethical business practices in all our dealings.</p>
        </div>
        
        <div class="text-center p-6">
          <div class="inline-block p-3 bg-blue-100 rounded-full mb-4">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Reliability</h3>
          <p class="text-gray-600">Consistent delivery and dependable service you can count on.</p>
        </div>
        
        <div class="text-center p-6">
          <div class="inline-block p-3 bg-blue-100 rounded-full mb-4">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Partnership</h3>
          <p class="text-gray-600">Building lasting relationships with clients and suppliers alike.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="py-16 bg-blue-900 text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Why Choose BINGOPLACE LIMITED?
      </h2>
      <div class="w-20 h-1 bg-yellow-500 mx-auto mb-8"></div>
      <div class="grid md:grid-cols-4 gap-6 max-w-5xl mx-auto">
        <div>
          <p class="text-3xl font-bold text-yellow-400 mb-2">2026</p>
          <p class="text-blue-100">Year Established</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-yellow-400 mb-2">100%</p>
          <p class="text-blue-100">Shareholder Commitment</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-yellow-400 mb-2">UK</p>
          <p class="text-blue-100">Nationwide Coverage</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-yellow-400 mb-2">46900</p>
          <p class="text-blue-100">SIC Code Specialization</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
        Ready to Work With Us?
      </h2>
      <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">
        Get in touch to discuss how BINGOPLACE LIMITED can support your wholesale and distribution needs.
      </p>
      <a href="/contact" class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-lg transition duration-300 transform hover:scale-105">
        Contact Us Today
      </a>
    </div>
  </section>
