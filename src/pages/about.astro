---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About Us | BINGOPLACE LIMITED | Wholesale & Distribution Manchester">
  <!-- Hero Section -->
  <section class="bg-linear-to-br from-blue-900 to-blue-700 text-white">
    <div class="container mx-auto px-4 py-16 md:py-20">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          About BINGOPLACE LIMITED
        </h1>
        <div class="w-20 h-1 bg-yellow-500 mx-auto mb-6"></div>
        <p class="text-xl text-blue-100">
          Your trusted partner in wholesale trade and distribution across the United Kingdom
        </p>
      </div>
    </div>
  </section>

  <!-- Company Story Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            Our Story
          </h2>
          <div class="w-20 h-1 bg-yellow-500 mx-auto mb-6"></div>
        </div>
        
        <div class="prose prose-lg max-w-none">
          <p class="text-gray-700 leading-relaxed mb-6">
            BINGOPLACE LIMITED was incorporated on <strong class="text-blue-600">29th January 2026</strong> with a vision to become a leading force in the UK wholesale and distribution sector. Based in Manchester, we bring together industry expertise, strategic partnerships, and a commitment to excellence that sets us apart in the competitive landscape of non-specialised wholesale trade.
          </p>
          
          <p class="text-gray-700 leading-relaxed mb-6">
            Our company operates under SIC code 46900, specializing in non-specialised wholesale trade. This classification allows us to maintain a versatile and adaptive approach to serving businesses across various industries, ensuring we can meet diverse client needs with agility and precision.
          </p>
          
          <p class="text-gray-700 leading-relaxed">
            At the heart of our operations is a dedication to building lasting partnerships. We understand that in today's dynamic business environment, success comes from reliability, transparency, and the ability to deliver consistently. These principles guide everything we do, from sourcing to distribution.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Company Information Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Company Information
        </h2>
        <div class="w-20 h-1 bg-yellow-500 mx-auto mb-6"></div>
        <p class="text-lg text-gray-600">
          Official registered details and corporate information
        </p>
      </div>
      
      <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="grid md:grid-cols-2">
            <div class="p-8 border-b md:border-b-0 md:border-r border-gray-200">
              <div class="flex items-center mb-4">
                <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mr-3">
                  <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-semibold text-gray-900">Company Details</h3>
              </div>
              <dl class="space-y-3">
                <div>
                  <dt class="text-sm font-medium text-gray-500">Company Name</dt>
                  <dd class="text-gray-900 font-medium">BINGOPLACE LIMITED</dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Company Number</dt>
                  <dd class="text-gray-900 font-medium">16998502</dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Company Type</dt>
                  <dd class="text-gray-900">Private company limited by shares</dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Incorporation Date</dt>
                  <dd class="text-gray-900">29th January 2026</dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Jurisdiction</dt>
                  <dd class="text-gray-900">England and Wales</dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-gray-500">SIC Code</dt>
                  <dd class="text-gray-900">46900 - Non-specialised wholesale trade</dd>
                </div>
              </dl>
            </div>
            
            <div class="p-8">
              <div class="flex items-center mb-4">
                <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mr-3">
                  <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-semibold text-gray-900">Registered Office</h3>
              </div>
              <dl class="space-y-3">
                <div>
                  <dt class="text-sm font-medium text-gray-500">Address</dt>
                  <dd class="text-gray-900">
                    76 King Street<br />
                    Manchester<br />
                    England<br />
                    M2 4NH<br />
                    United Kingdom
                  </dd>
                </div>
              </dl>
              
              <div class="mt-6 pt-6 border-t border-gray-200">
                <div class="flex items-center mb-4">
                  <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mr-3">
                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <h3 class="text-xl font-semibold text-gray-900">Status</h3>
                </div>
                <p class="text-gray-700">
                  Active and compliant with all Companies Act 2006 requirements.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

